# Kitchen Buddy — environment variables
#
# Copy this file to `.env.local` (gitignored) for local frontend dev.
# Values here are for the FRONTEND (Vite) build. Edge function secrets are
# NOT set via .env files — see SETUP.md, they're set with
# `supabase secrets set ...` and live only in the Supabase project.

# Supabase project URL and anon (public) key.
# Find these in: Supabase Dashboard > Project Settings > API.
# Safe to expose in frontend bundles (RLS protects the data).
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_ANON_KEY

# LIFF app ID from the LINE Developers console (LINE Login channel > LIFF tab).
# If left UNSET, the frontend should run in mock mode (fake LINE user, no
# LINE account needed) per CLAUDE.md.
VITE_LIFF_ID=

# ---------------------------------------------------------------------------
# The following are EDGE FUNCTION secrets, NOT read from this file.
# Set them with:
#   supabase secrets set LINE_CHANNEL_ID=... LINE_MESSAGING_ACCESS_TOKEN=... SB_JWT_SECRET=...
# Listed here only for reference — see SETUP.md for the full click-path.
# ---------------------------------------------------------------------------
# LINE_CHANNEL_ID                -> LINE Login channel ID (used by line-auth to verify id_token aud)
# LINE_MESSAGING_ACCESS_TOKEN    -> Messaging API channel access token (used by daily-digest to push)
# SB_JWT_SECRET                  -> Supabase project JWT secret (Project Settings > API > JWT Settings),
#                                    used by line-auth to mint Supabase-compatible access tokens.
#                                    NOTE: cannot be named SUPABASE_JWT_SECRET -- the "SUPABASE_" prefix
#                                    is reserved by the platform and `supabase secrets set` rejects it.
# SUPABASE_URL / SUPABASE_SERVICE_ROLE_KEY -> auto-injected by the Supabase platform for every edge
#                                    function. Do not set these manually.
